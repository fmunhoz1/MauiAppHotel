<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Sobre"
             Title="Sobre"
             BackgroundColor="{StaticResource Tertiary}">

    <VerticalStackLayout Padding="20"
                         VerticalOptions="Center"
                         Spacing="20">

        <Label Text="Sobre o Projeto"
               FontFamily="FinlandicaTextBold"
               FontSize="32"
               HorizontalOptions="Center"
               TextColor="{StaticResource Tertiary}" />

        <Frame Padding="20"
               BackgroundColor="{StaticResource Black}"
               BorderColor="{StaticResource Black}"
               CornerRadius="20">

            <VerticalStackLayout Spacing="15">

                <Label Text="Desenvolvedor: Fernando Munhoz"
                       FontFamily="FinlandicaTextRegular"
                       FontSize="18"
                       TextColor="{StaticResource White}" />

                <Label Text="Ano de desenvolvimento: 2026"
                       FontFamily="FinlandicaTextRegular"
                       FontSize="18"
                       TextColor="{StaticResource White}" />

                <Label Text="Aplicativo desenvolvido utilizando .NET MAUI."
                       FontFamily="FinlandicaTextRegular"
                       FontSize="18"
                       TextColor="{StaticResource White}" />

            </VerticalStackLayout>

        </Frame>

        <Button Text="Voltar"
                Clicked="BtnVoltar_Clicked"
                FontFamily="FinlandicaTextBold"
                BackgroundColor="{StaticResource Primary}"
                TextColor="{StaticResource White}"
                CornerRadius="12"/>

    </VerticalStackLayout>

</ContentPage>